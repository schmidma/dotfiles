[Unit]
Description=Swayidle watch logind
PartOf=graphical-session.target
Requisite=graphical-session.target
After=graphical-session.target

[Service]
ExecStart=swayidle timeout 10 %h/.config/niri/scripts/poweroff-when-locked resume 'niri msg action power-on-monitors'
Restart=on-failure
RestartSec=1

[Install]
WantedBy=graphical-session.target
