[general]
# A folder where vdirsyncer can store some metadata about each pair.
status_path = "~/.cache/vdirsyncer/"

### Mailbox carddav
[pair Mailbox]
a = "MailboxLocal"
b = "MailboxRemote"
collections = ["from b"]
metadata = ["Mailbox"]
conflict_resolution = "b wins"

[storage MailboxLocal]
type = "filesystem"
path = "~/.contacts/Mailbox/"
fileext = ".vcf"

[storage MailboxRemote]
type = "carddav"
url = "https://dav.mailbox.org/carddav/32"
username = "8768771@8768771"
password.fetch = ["command", "gopass", "--password", "mailbox-app-password"]
